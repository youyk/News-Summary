# Optional source credentials for Stage A collector.
# Copy to scripts/news_sources.env and keep it local (gitignored).

# Reddit OAuth (recommended if reddit JSON/RSS endpoints are blocked)
# export REDDIT_CLIENT_ID="your_reddit_client_id"
# export REDDIT_CLIENT_SECRET="your_reddit_client_secret"

# Weibo hot search (public endpoint, cookie optional but improves stability).
# Export full browser cookie string only in local file.
# export WEIBO_COOKIE="SUB=...; SUBP=...; ..."

# Toutiao hot board (public endpoint, cookie optional).
# export TOUTIAO_COOKIE="ttwid=...; ..."

# X via Nitter RSS (best-effort, may be blocked by network policy).
# Provide handles without @, comma-separated.
# export X_HANDLES="openai,elonmusk,sama"
# Optional nitter mirrors, comma-separated.
# export X_NITTER_INSTANCES="https://nitter.net,https://nitter.poast.org"

# Optional RSS sources for X / Xiaohongshu (for RSSHub or other bridge services).
# export X_RSS_URLS="https://rsshub.example.com/twitter/user/openai"
# export XIAOHONGSHU_RSS_URLS="https://rsshub.example.com/xiaohongshu/user/5f..."

# Optional Reddit/X Playwright fallback collector (for API/RSS blocked scenarios).
# 1) Install once:
#    python3 -m venv /Users/yongkang/projects/skills/News-Summary/.venv
#    /Users/yongkang/projects/skills/News-Summary/.venv/bin/python -m pip install playwright
# 2) Enable collector:
# export ENABLE_SOCIAL_PLAYWRIGHT=1
# export NEWS_SUMMARY_PLAYWRIGHT_PYTHON_BIN="/Users/yongkang/projects/skills/News-Summary/.venv/bin/python"
# 3) Configure targets:
# export REDDIT_PLAYWRIGHT_SUBREDDITS="news,worldnews,technology,artificial"
# export X_PLAYWRIGHT_HANDLES="openai,sama,elonmusk"
# 3.5) Prefer local Chrome channel (avoid downloading bundled chromium):
# export SOCIAL_PLAYWRIGHT_CHANNEL="chrome"
# Optional: lower automation fingerprint (useful when Google SSO says browser not secure)
# export SOCIAL_PLAYWRIGHT_STEALTH_LOGIN=1
# # or explicit binary path:
# # export SOCIAL_PLAYWRIGHT_EXECUTABLE_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
# 4) First run login warmup (headed):
# export SOCIAL_PLAYWRIGHT_LOGIN_WAIT_SECONDS=120
# export SOCIAL_PLAYWRIGHT_HEADLESS=0
#    Note: Reddit may return "blocked by network security" without a logged-in profile.
# 5) Optional profile path / per-source cap:
# # default profile path is inside project: /Users/yongkang/projects/skills/News-Summary/.cache/news-summary/social-playwright-profile
# export SOCIAL_PLAYWRIGHT_USER_DATA_DIR="/Users/yongkang/projects/skills/News-Summary/.cache/news-summary/social-playwright-profile"
# export SOCIAL_PLAYWRIGHT_MAX_PER_SOURCE=20
# Optional anti-risk-control throttling (recommended):
# export SOCIAL_PLAYWRIGHT_DELAY_MIN_SECONDS=2.5
# export SOCIAL_PLAYWRIGHT_DELAY_MAX_SECONDS=6.5
# export SOCIAL_PLAYWRIGHT_SOURCE_COOLDOWN_SECONDS=8
# 6) Fail-fast if this collector is mandatory:
# export SOCIAL_PLAYWRIGHT_REQUIRED=1
# 7) Optional minimum-item gates (recommended when fallback must be effective):
# export SOCIAL_PLAYWRIGHT_REQUIRE_REDDIT_ITEMS=1
# export SOCIAL_PLAYWRIGHT_REQUIRE_X_ITEMS=1
# 8) Baseline mode default skips stale auto-generated manual files from prior recovery runs.
# Set to 1 only if you intentionally want to reuse last social/xhs Playwright manual JSON.
# export PLAYWRIGHT_USE_LAST_MANUAL_FILES=0

# Optional Xiaohongshu Playwright collector (recommended when web URLs need login/mobile context).
# 1) Install once:
#    python3 -m venv /Users/yongkang/projects/skills/News-Summary/.venv
#    /Users/yongkang/projects/skills/News-Summary/.venv/bin/python -m pip install playwright
# 2) Enable:
# export ENABLE_XHS_PLAYWRIGHT=1
# export NEWS_SUMMARY_PLAYWRIGHT_PYTHON_BIN="/Users/yongkang/projects/skills/News-Summary/.venv/bin/python"
# 3) Provide URLs:
# export XIAOHONGSHU_SHARE_URLS="https://www.xiaohongshu.com/discovery/item/...,https://..."
# or:
# export XIAOHONGSHU_URLS_FILE="/Users/yongkang/projects/skills/News-Summary/data/inbox/manual/xiaohongshu_urls.txt"
# 3.5) Prefer local Chrome channel:
# export XHS_PLAYWRIGHT_CHANNEL="chrome"
# # or explicit binary path:
# # export XHS_PLAYWRIGHT_EXECUTABLE_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
# 4) First run can reserve login time in headed mode:
# export XHS_LOGIN_WAIT_SECONDS=90
# export XHS_PLAYWRIGHT_HEADLESS=0
# 5) Optional profile path:
# # default profile path is inside project: /Users/yongkang/projects/skills/News-Summary/.cache/news-summary/xhs-playwright-profile
# export XHS_PLAYWRIGHT_USER_DATA_DIR="/Users/yongkang/projects/skills/News-Summary/.cache/news-summary/xhs-playwright-profile"
# 6) Fail-fast if xhs capture is mandatory:
# export XHS_PLAYWRIGHT_REQUIRED=1

# Optional runtime toggles:
# export DISABLE_WEIBO_HOTSEARCH=1
# export DISABLE_TOUTIAO_HOTBOARD=1
