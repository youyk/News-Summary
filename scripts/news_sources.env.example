# Optional source credentials for Stage A collector.
# Copy to scripts/news_sources.env and keep it local (gitignored).

# Reddit OAuth (recommended if reddit JSON/RSS endpoints are blocked)
# export REDDIT_CLIENT_ID="your_reddit_client_id"
# export REDDIT_CLIENT_SECRET="your_reddit_client_secret"

# Weibo hot search (public endpoint, cookie optional but improves stability).
# Export full browser cookie string only in local file.
# export WEIBO_COOKIE="SUB=...; SUBP=...; ..."

# Toutiao hot board (public endpoint, cookie optional).
# export TOUTIAO_COOKIE="ttwid=...; ..."

# X via Nitter RSS (best-effort, may be blocked by network policy).
# Provide handles without @, comma-separated.
# export X_HANDLES="openai,elonmusk,sama"
# Optional nitter mirrors, comma-separated.
# export X_NITTER_INSTANCES="https://nitter.net,https://nitter.poast.org"

# Optional RSS sources for X / Xiaohongshu (for RSSHub or other bridge services).
# export X_RSS_URLS="https://rsshub.example.com/twitter/user/openai"
# export XIAOHONGSHU_RSS_URLS="https://rsshub.example.com/xiaohongshu/user/5f..."

# Optional Xiaohongshu Playwright collector (recommended when web URLs need login/mobile context).
# 1) Install once:
#    pip3 install playwright
#    playwright install chromium
# 2) Enable:
# export ENABLE_XHS_PLAYWRIGHT=1
# 3) Provide URLs:
# export XIAOHONGSHU_SHARE_URLS="https://www.xiaohongshu.com/discovery/item/...,https://..."
# or:
# export XIAOHONGSHU_URLS_FILE="/Users/yongkang/projects/skills/News-Summary/data/inbox/manual/xiaohongshu_urls.txt"
# 4) First run can reserve login time in headed mode:
# export XHS_LOGIN_WAIT_SECONDS=90
# export XHS_PLAYWRIGHT_HEADLESS=0
# 5) Optional profile path:
# export XHS_PLAYWRIGHT_USER_DATA_DIR="$HOME/.cache/news-summary/xhs-playwright-profile"
# 6) Fail-fast if xhs capture is mandatory:
# export XHS_PLAYWRIGHT_REQUIRED=1

# Optional runtime toggles:
# export DISABLE_WEIBO_HOTSEARCH=1
# export DISABLE_TOUTIAO_HOTBOARD=1
