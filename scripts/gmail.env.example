export GMAIL_CLIENT_ID="YOUR_CLIENT_ID"
export GMAIL_CLIENT_SECRET="YOUR_CLIENT_SECRET"
export GMAIL_REFRESH_TOKEN="YOUR_REFRESH_TOKEN"
export GMAIL_FROM="your-address@gmail.com"
export NEWS_DIGEST_TO="recipient@example.com"
export NEWS_DIGEST_MAIL_CONTENT_MODE="multipart"
export NEWS_DIGEST_MIN_ENGLISH_WORDS="200"
# export NEWS_DIGEST_SKIP_VALIDATE="1"  # emergency override, not recommended

# Optional stability tuning for cron/network jitter:
# export GMAIL_HTTP_RETRIES="4"
# export GMAIL_HTTP_BACKOFF_SECONDS="2"
# export GMAIL_HTTP_TIMEOUT_SECONDS="30"

# Optional proxy settings if your network requires proxy to reach Google APIs:
# export HTTPS_PROXY="http://127.0.0.1:7890"
# export HTTP_PROXY="http://127.0.0.1:7890"
