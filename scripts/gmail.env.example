export NEWS_DIGEST_TO="recipient@example.com"
export NEWS_DIGEST_MAIL_CONTENT_MODE="multipart"
export NEWS_DIGEST_MIN_ENGLISH_WORDS="200"
export NEWS_DIGEST_COMMENT_MODE="off"
